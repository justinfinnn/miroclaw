# =============================================================
# MiroClaw — Configuration
# =============================================================
# Three execution modes: ollama (default), api_key, codex
# Copy this file to .env and adjust for your setup.
# =============================================================

# ===== Execution Mode =====
# ollama   — Fully offline, local Ollama LLM + embeddings (default)
# api_key  — Any OpenAI-compatible API with a real API key
# codex    — OpenAI Codex OAuth via OpenClaw bridge
MODELING_BACKEND=ollama

# ===== LLM Configuration (OpenAI-compatible format) =====
# --- Mode: ollama (default) ---
# Any non-empty value works as API key for Ollama
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:32b

# --- Mode: api_key ---
# Uncomment and set your real API key:
# MODELING_BACKEND=api_key
# LLM_API_KEY=sk-your-api-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# --- Mode: codex ---
# Requires OpenClaw with openai-codex OAuth login
# MODELING_BACKEND=codex
# CODEX_MODEL_NAME=gpt-5.4
# LLM_API_KEY can be left unset in codex mode

# ===== Neo4j Configuration =====
# For Docker: use service name "neo4j" instead of "localhost"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish

# ===== Embedding Configuration (Ollama) =====
# Used in ollama mode for local embedding generation
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434
# For Docker: EMBEDDING_BASE_URL=http://ollama:11434

# ===== OASIS / CAMEL-AI Configuration =====
# CAMEL-AI reads these vars. Point to same LLM backend.
OPENAI_API_KEY=ollama
OPENAI_API_BASE_URL=http://localhost:11434/v1

# ===== Ollama Tuning =====
# Context window size (default 8192, Ollama default is only 2048)
# OLLAMA_NUM_CTX=8192

# ===== Codex Rate Limiting (only for MODELING_BACKEND=codex) =====
# CODEX_GRAPHITI_CONCURRENCY=1
# CODEX_GRAPHITI_MIN_DELAY_SECS=2.0
# CODEX_GRAPHITI_MAX_RETRIES=10

# ===== Docker-mode overrides =====
# Uncomment when running ALL services inside Docker
# LLM_BASE_URL=http://ollama:11434/v1
# NEO4J_URI=bolt://neo4j:7687
# EMBEDDING_BASE_URL=http://ollama:11434
# OPENAI_API_BASE_URL=http://ollama:11434/v1
